class loadWavdata(threading.Thread):

	def __init__(self):
		global flagWavstart
		threading.Thread.__init__(self)
		self.audio_capture = None
		self.inp = None
		self.audio_available = False
		
		if PYAUDIO_AVAILABLE:
			try:
				print("🎵 正在初始化PyAudioCapture...")
