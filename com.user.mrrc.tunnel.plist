<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.mrrc.tunnel</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/Users/cheenle/UHRR/MRRC/mrrc_tunnel.sh</string>
        <string>monitor</string>
    </array>
    
    <key>WorkingDirectory</key>
    <string>/Users/cheenle/UHRR/MRRC</string>
    
    <key>RunAtLoad</key>
    <true/>
    
